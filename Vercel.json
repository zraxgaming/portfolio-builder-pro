{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "serverlessFunctionRegion": "iad1",
  "framework": "vite",
  "functions": {
    "api/handler.ts": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/client/(.*)", "dest": "/client/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/api/handler" }
  ]
}
